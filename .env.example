PUB_KEY="your-public-key-here"
DNSTT_DOMAIN="your-domain-here"
SSH_USER="root"
DNSTT_BIN="./dnstt-client-darwin-arm64"
DNS_LIST_FILE="scan.csv"
OUTPUT_FILE="working-dns.txt"
MAX_WAIT_TIME=45
BASE_PORT=10000
MAX_PARALLEL=5

# --- Adaptive Timeout ---
STREAM_TIMEOUT=8          # Max seconds to wait for dnstt stream creation (Phase 1)
AUTH_TIMEOUT=20            # Max seconds to wait for SSH auth after stream (Phase 2)

# --- Pre-filter ---
PREFILTER=true             # Pre-filter IPs by checking port 53 responsiveness
PREFILTER_TIMEOUT=2        # Seconds to wait for DNS response in pre-filter

# --- Scan Mode ---
SCAN_MODE=udp              # Options: udp, dot (DNS-over-TLS on port 853), both

# --- Resume & Dead Cache ---
RESUME_FILE=               # Path to previous scan_progress_*.dat file to resume from
DEAD_CACHE_MAX_AGE=86400   # Skip dead IPs seen within this many seconds (default: 24h)
